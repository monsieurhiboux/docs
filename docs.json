{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Otterly Space Docs LLM",
  "colors": {
    "primary": "#3B82F6",
    "light": "#3B82F6",
    "dark": "#243A90"
  },
  "fonts": {
    "heading": {
      "family": "Inter",
      "weight": 700
    },
    "body": {
      "family": "Inter",
      "weight": 400
    }
  },
  "background": {
    "decoration": "grid",
    "color": {
      "light": "#F5F7FB",
      "dark": "#0F172A"
    }
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "MLX Framework",
        "groups": [
          {
            "group": "Démarrer",
            "pages": [
              "mlx/introduction",
              "mlx/installation",
              "mlx/quickstart"
            ]
          },
          {
            "group": "Modèles",
            "pages": [
              "mlx/models/mlx-community",
              "mlx/models/quantization"
            ]
          },
          {
            "group": "Ressources",
            "pages": [
              "mlx/ecosystem/awesome-mlx",
              "mlx/resources/community",
              "mlx/resources/official-repos"
            ]
          }
        ]
      },
      {
        "tab": "LLMs sur Mac",
        "groups": [
          {
            "group": "Inférence",
            "pages": [
              "mlx/local-llms/overview",
              "mlx/local-llms/mlx-lm-generate",
              "mlx/local-llms/ollama-llamacpp"
            ]
          },
          {
            "group": "Fine-Tuning",
            "pages": [
              "mlx/fine-tuning/lora-guide",
              "mlx/fine-tuning/qlora-guide",
              "mlx/fine-tuning/dataset-preparation",
              "mlx/fine-tuning/tips-and-tricks"
            ]
          },
          {
            "group": "Intégration Apps",
            "pages": [
              "mlx/local-llms/swift-integration"
            ]
          }
        ]
      },
      {
        "tab": "Apple Foundation Models",
        "groups": [
          {
            "group": "Démarrer",
            "pages": [
              "mlx/foundation-models/introduction",
              "mlx/foundation-models/availability"
            ]
          },
          {
            "group": "Construire des prompts",
            "pages": [
              "mlx/foundation-models/prompts",
              "mlx/foundation-models/instructions"
            ]
          },
          {
            "group": "Fonctionnalités avancées",
            "pages": [
              "mlx/foundation-models/guided-generation",
              "mlx/foundation-models/tools",
              "mlx/foundation-models/streaming-ux"
            ]
          },
          {
            "group": "Production",
            "pages": [
              "mlx/foundation-models/session-lifecycle",
              "mlx/foundation-models/error-handling",
              "mlx/foundation-models/architecture-patterns"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub MLX",
          "href": "https://github.com/ml-explore/mlx",
          "icon": "github"
        },
        {
          "anchor": "MLX Community HF",
          "href": "https://huggingface.co/mlx-community",
          "icon": "users"
        },
        {
          "anchor": "WWDC25 Talk",
          "href": "https://developer.apple.com/videos/play/wwdc2025/298",
          "icon": "video"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "X",
